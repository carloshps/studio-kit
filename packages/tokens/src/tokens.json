{
  "$schema": "https://studio-kit.carloshps.com.br/schema/tokens.json",
  "meta": {
    "source": "marca/design-guide.md",
    "theme": "dark-primary"
  },
  "color": {
    "background": {
      "DEFAULT": "#081424",
      "secondary": "#030C17",
      "card": "rgba(8,20,36,0.92)"
    },
    "foreground": {
      "DEFAULT": "rgba(232,244,251,0.92)",
      "muted": "rgba(232,244,251,0.45)",
      "subtle": "rgba(232,244,251,0.40)"
    },
    "accent": {
      "DEFAULT": "#00ADCF",
      "border": "rgba(0,173,207,0.18)",
      "border-card": "rgba(0,173,207,0.25)",
      "border-subtle": "rgba(0,173,207,0.10)",
      "cta-bg": "rgba(0,173,207,0.20)",
      "eyebrow": "rgba(0,173,207,0.30)",
      "avatar-ring": "rgba(0,173,207,0.40)",
      "glow-min": "rgba(0,173,207,0.06)",
      "logo-bg": "rgba(0,173,207,0.35)"
    },
    "overlay": {
      "pill-bg": "rgba(255,255,255,0.05)",
      "pill-border": "rgba(255,255,255,0.08)"
    }
  },
  "typography": {
    "fontFamily": {
      "sans": ["Manrope", "system-ui", "sans-serif"]
    },
    "fontWeight": {
      "brand-strong": "800",
      "brand-light": "400"
    }
  },
  "shadow": {
    "hero": "0 0 0 1px rgba(0,173,207,0.06), 0 24px 64px rgba(0,5,14,0.55), inset 0 1px 0 rgba(0,173,207,0.08)",
    "card": "0 8px 32px rgba(0,5,14,0.50), 0 0 0 1px rgba(0,173,207,0.06)",
    "metric": "0 8px 24px rgba(0,5,14,0.45)",
    "glow-text": "0 0 16px rgba(0,173,207,0.4)"
  },
  "gradient": {
    "avatar": "linear-gradient(145deg, rgba(0,173,207,0.18) 0%, rgba(8,20,36,0.80) 100%)",
    "result": "linear-gradient(160deg, rgba(0,80,140,0.45) 0%, rgba(0,30,70,0.70) 100%)"
  },
  "radius": {
    "DEFAULT": "0.5rem"
  }
}
