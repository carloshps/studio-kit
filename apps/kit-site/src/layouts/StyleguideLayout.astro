---
import "@studio/tokens/css";
import "../styles/global.css";
import { navigation } from "../data/navigation";

interface Props {
  title?: string
  description?: string
}

const { title = "Studio Kit", description = "" } = Astro.props;
const pathname = Astro.url.pathname;

// Determina a seção ativa para highlight na sidebar
function isActive(href: string) {
  if (href.includes("#")) {
    return pathname === href.split("#")[0];
  }
  return pathname === href || pathname.startsWith(href + "/");
}

function getSectionActive(items: { href: string }[]) {
  return items.some(i => isActive(i.href));
}
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Studio Kit</title>
    {description && <meta name="description" content={description} />}
    <script is:inline>
      try { if (localStorage.getItem("theme") === "light") document.documentElement.classList.add("light"); } catch(_) {}
    </script>
  </head>

  <body class="min-h-screen bg-background text-foreground/90 font-sans antialiased">

    <!-- Mobile: overlay backdrop -->
    <div id="sidebar-backdrop" class="fixed inset-0 z-20 bg-background/80 backdrop-blur-sm hidden lg:hidden"></div>

    <!-- Sidebar -->
    <aside
      id="sidebar"
      class="fixed top-0 left-0 z-30 h-screen w-64 flex flex-col
             border-r border-border/10 bg-background
             -translate-x-full lg:translate-x-0
             transition-transform duration-200 ease-in-out"
    >
      <!-- Cabeçalho da sidebar -->
      <div class="flex items-center justify-between px-5 py-4 border-b border-border/10 shrink-0">
        <a href="/" class="flex items-center gap-2 group">
          <span class="w-6 h-6 rounded bg-primary flex items-center justify-center shrink-0">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="1" y="1" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground"/>
              <rect x="7" y="1" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground/60"/>
              <rect x="1" y="7" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground/60"/>
              <rect x="7" y="7" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground/30"/>
            </svg>
          </span>
          <span class="text-sm font-bold text-foreground/90 group-hover:text-foreground transition-colors">
            Studio Kit
          </span>
        </a>
        <!-- Fechar (mobile) -->
        <button
          id="sidebar-close"
          aria-label="Fechar menu"
          class="lg:hidden p-1 rounded text-foreground/40 hover:text-foreground/70 transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M3 3l10 10M13 3L3 13"/>
          </svg>
        </button>
      </div>

      <!-- Nav scrollável -->
      <nav class="flex-1 overflow-y-auto py-4 px-3">
        {navigation.map((section) => (
          <div class="mb-5">
            <p class="px-2 mb-1.5 text-[10px] font-semibold uppercase tracking-widest text-foreground/30">
              {section.title}
            </p>
            <ul class="space-y-0.5">
              {section.items.map((item) => (
                <li>
                  <a
                    href={item.href}
                    class={[
                      "flex items-center justify-between px-2 py-1.5 rounded-md text-sm transition-colors",
                      isActive(item.href)
                        ? "bg-primary/15 text-primary font-medium"
                        : "text-foreground/60 hover:text-foreground/90 hover:bg-accent/10"
                    ].join(" ")}
                  >
                    <span>{item.name}</span>
                    {item.badge && (
                      <span class="text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded-full bg-accent/20 text-foreground/50">
                        {item.badge}
                      </span>
                    )}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

      <!-- Rodapé da sidebar: links + toggle tema -->
      <div class="px-3 py-3 border-t border-border/10 shrink-0 flex items-center justify-between gap-2">
        <div class="flex items-center gap-1">
          <a
            href="/docs"
            class="px-2 py-1.5 text-xs text-foreground/40 hover:text-foreground/70 rounded transition-colors"
          >
            Docs
          </a>
          <a
            href="https://github.com/CarlosHPS/studio-kit"
            target="_blank"
            rel="noopener noreferrer"
            class="px-2 py-1.5 text-xs text-foreground/40 hover:text-foreground/70 rounded transition-colors"
          >
            GitHub
          </a>
        </div>

        <!-- Toggle dark/light -->
        <button
          id="theme-toggle"
          aria-label="Alternar tema"
          class="flex items-center justify-center w-7 h-7 rounded-md text-foreground/40 hover:text-foreground/70 hover:bg-accent/10 transition-colors"
        >
          <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M6.34 17.66l-1.41 1.41M19.07 4.93l-1.41 1.41"/>
          </svg>
          <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
            <path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/>
          </svg>
        </button>
      </div>
    </aside>

    <!-- Conteúdo principal (offset pela sidebar no desktop) -->
    <div class="lg:ml-64 min-h-screen flex flex-col">

      <!-- Top bar mobile -->
      <header class="lg:hidden sticky top-0 z-10 flex items-center gap-3 px-4 py-3 border-b border-border/10 bg-background/90 backdrop-blur-sm">
        <button
          id="sidebar-open"
          aria-label="Abrir menu"
          class="p-1.5 rounded-md text-foreground/60 hover:text-foreground/90 hover:bg-accent/10 transition-colors"
        >
          <svg width="16" height="16" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M2 4h12M2 8h12M2 12h12"/>
          </svg>
        </button>
        <span class="text-sm font-semibold text-foreground/70">{title}</span>
      </header>

      <main class="flex-1">
        <slot />
      </main>
    </div>

    <script>
      const html = document.documentElement;
      const btn  = document.getElementById("theme-toggle");
      const sun  = document.getElementById("icon-sun");
      const moon = document.getElementById("icon-moon");

      function applyTheme(isLight: boolean) {
        html.classList.toggle("light", isLight);
        sun?.classList.toggle("hidden", isLight);
        moon?.classList.toggle("hidden", !isLight);
      }

      applyTheme(html.classList.contains("light"));

      btn?.addEventListener("click", () => {
        const nowLight = !html.classList.contains("light");
        applyTheme(nowLight);
        try { localStorage.setItem("theme", nowLight ? "light" : "dark"); } catch(_) {}
      });

      // Sidebar mobile
      const sidebar   = document.getElementById("sidebar");
      const backdrop  = document.getElementById("sidebar-backdrop");
      const openBtn   = document.getElementById("sidebar-open");
      const closeBtn  = document.getElementById("sidebar-close");

      function openSidebar() {
        sidebar?.classList.remove("-translate-x-full");
        backdrop?.classList.remove("hidden");
        document.body.style.overflow = "hidden";
      }
      function closeSidebar() {
        sidebar?.classList.add("-translate-x-full");
        backdrop?.classList.add("hidden");
        document.body.style.overflow = "";
      }

      openBtn?.addEventListener("click", openSidebar);
      closeBtn?.addEventListener("click", closeSidebar);
      backdrop?.addEventListener("click", closeSidebar);
    </script>
  </body>
</html>
