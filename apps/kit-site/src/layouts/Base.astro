---
import "@studio/tokens/css";
import "../styles/global.css";
import MegaNav from "../components/MegaNav.astro";
const { title = "Studio Kit" } = Astro.props;
---
<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Studio Kit</title>
    <!-- Aplica tema salvo antes da renderização para evitar flash -->
    <script is:inline>
      (function () {
        try {
          if (localStorage.getItem("theme") === "light") {
            document.documentElement.classList.add("light");
          }
        } catch (_) {}
      })();
    </script>
  </head>
  <body class="min-h-screen bg-background text-foreground/90 font-sans antialiased">

    <MegaNav />

    <slot />

    <footer class="border-t border-border/10 px-6 py-8 mt-16">
      <div class="mx-auto max-w-5xl flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-foreground/40">
        <span>Studio Kit — CarlosHPS Studio</span>
        <a href="/docs" class="hover:text-foreground/70 transition-colors">Docs</a>
      </div>
    </footer>

  </body>
</html>
