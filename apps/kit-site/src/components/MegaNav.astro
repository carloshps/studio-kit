<style>
  .mega-panel {
    visibility: hidden;
    opacity: 0;
    pointer-events: none;
    transition: opacity 120ms ease, visibility 120ms ease;
  }
  [data-mega-group]:hover .mega-panel {
    visibility: visible;
    opacity: 1;
    pointer-events: auto;
  }
  [data-mega-group]:hover .mega-chevron {
    transform: rotate(180deg);
  }
</style>

<script>
  // ── Theme toggle ──────────────────────────────────────────
  const html = document.documentElement;

  function applyTheme(isLight: boolean) {
    html.classList.toggle("light", isLight);
    document.querySelectorAll("#icon-sun").forEach(el => el.classList.toggle("hidden", isLight));
    document.querySelectorAll("#icon-moon").forEach(el => el.classList.toggle("hidden", !isLight));
  }

  applyTheme(html.classList.contains("light"));

  document.querySelectorAll("#theme-toggle").forEach(btn => {
    btn.addEventListener("click", () => {
      const nowLight = !html.classList.contains("light");
      applyTheme(nowLight);
      try { localStorage.setItem("theme", nowLight ? "light" : "dark"); } catch (_) {}
    });
  });

  // ── Mobile menu toggle ────────────────────────────────────
  const mobileBtn = document.getElementById("mobile-menu-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const mobileIconOpen = document.getElementById("mobile-icon-open");
  const mobileIconClose = document.getElementById("mobile-icon-close");

  mobileBtn?.addEventListener("click", () => {
    const isOpen = mobileMenu?.classList.toggle("hidden") === false;
    mobileBtn.setAttribute("aria-expanded", String(isOpen));
    mobileIconOpen?.classList.toggle("hidden", isOpen);
    mobileIconClose?.classList.toggle("hidden", !isOpen);
  });

  // Fechar ao clicar em link dentro do menu mobile
  mobileMenu?.querySelectorAll("a").forEach(link => {
    link.addEventListener("click", () => {
      mobileMenu.classList.add("hidden");
      mobileBtn?.setAttribute("aria-expanded", "false");
      mobileIconOpen?.classList.remove("hidden");
      mobileIconClose?.classList.add("hidden");
    });
  });

  // ── Mobile accordion sections ─────────────────────────────
  document.querySelectorAll(".mobile-section-btn").forEach(btn => {
    btn.addEventListener("click", () => {
      const section = btn.closest(".mobile-section");
      const content = section?.querySelector(".mobile-section-content");
      const chevron = btn.querySelector(".mobile-section-chevron");
      const isOpen = content?.classList.toggle("hidden") === false;
      btn.setAttribute("aria-expanded", String(isOpen));
      if (chevron instanceof HTMLElement) {
        chevron.style.transform = isOpen ? "rotate(180deg)" : "";
      }
    });
  });
</script>
