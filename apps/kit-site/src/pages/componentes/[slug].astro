                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  Top
                </button>
              </div>

              <!-- bottom -->
              <div class="relative flex flex-col items-center gap-2">
                <button class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-border/25 bg-transparent px-3 py-1.5 text-xs font-medium text-foreground/70 hover:bg-accent/10 transition-colors">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  Bottom
                </button>
                <div class="w-px h-1.5 bg-border/20"></div>
                <div class="z-10 max-w-xs rounded-md border border-border/18 bg-card px-3 py-1.5 text-xs text-foreground/80 shadow-md whitespace-nowrap">
                  Dica abaixo
                </div>
              </div>

              <!-- right -->
              <div class="relative flex items-center gap-2">
                <button class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-border/25 bg-transparent px-3 py-1.5 text-xs font-medium text-foreground/70 hover:bg-accent/10 transition-colors">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
                  Right
                </button>
                <div class="h-px w-1.5 bg-border/20"></div>
                <div class="z-10 max-w-xs rounded-md border border-border/18 bg-card px-3 py-1.5 text-xs text-foreground/80 shadow-md whitespace-nowrap">
                  Dica à direita
                </div>
              </div>

            </div>

            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-4">Interativo (hover)</p>
              <div class="rounded-xl border border-border/10 bg-card/30 p-8 flex flex-wrap gap-4 items-center">
                <div class="relative group/tt">
                  <button class="inline-flex items-center gap-1.5 rounded-lg bg-primary/10 border border-primary/25 px-4 py-2 text-sm font-medium text-primary/80 hover:bg-primary/15 transition-colors">
                    Copiar link
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
                  </button>
                  <div class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 group-hover/tt:opacity-100 transition-opacity duration-150 z-10">
                    <div class="rounded-md border border-border/18 bg-card px-3 py-1.5 text-xs text-foreground/80 shadow-md whitespace-nowrap">
                      Copiar URL para área de transferência
                    </div>
                  </div>
                </div>

                <div class="relative group/tt">
                  <button class="inline-flex items-center gap-1.5 rounded-lg border border-border/25 bg-transparent px-4 py-2 text-sm font-medium text-foreground/60 hover:bg-accent/10 transition-colors">
                    Excluir
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/></svg>
                  </button>
                  <div class="pointer-events-none absolute bottom-full left-1/2 -translate-x-1/2 mb-2 opacity-0 group-hover/tt:opacity-100 transition-opacity duration-150 z-10">
                    <div class="rounded-md border border-red-500/30 bg-card px-3 py-1.5 text-xs text-red-300/80 shadow-md whitespace-nowrap">
                      Ação irreversível
                    </div>
                  </div>
                </div>
              </div>
              <p class="text-xs text-foreground/30 mt-3">CSS hover demo — em produção usa Radix Tooltip com portal, teclado e delay configurável.</p>
            </div>
          </div>
        )}

        <!-- TOAST demo -->
        {component.slug === "toast" && (
          <div class="space-y-6">
            <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-4">Disparo interativo</p>
            <div class="relative rounded-xl border border-border/10 bg-card/30 p-8 overflow-hidden min-h-[200px]">
              <div class="flex flex-wrap gap-3 items-start">
                <button data-toast-trigger="default" class="inline-flex items-center gap-1.5 rounded-lg border border-border/25 bg-transparent px-4 py-2 text-sm font-medium text-foreground/70 hover:bg-accent/10 transition-colors">
                  Default
                </button>
                <button data-toast-trigger="success" class="inline-flex items-center gap-1.5 rounded-lg border border-emerald-500/30 bg-emerald-500/10 px-4 py-2 text-sm font-medium text-emerald-300 hover:bg-emerald-500/15 transition-colors">
                  Success
                </button>
                <button data-toast-trigger="warning" class="inline-flex items-center gap-1.5 rounded-lg border border-amber-500/30 bg-amber-500/10 px-4 py-2 text-sm font-medium text-amber-300 hover:bg-amber-500/15 transition-colors">
                  Warning
                </button>
                <button data-toast-trigger="error" class="inline-flex items-center gap-1.5 rounded-lg border border-red-500/30 bg-red-500/10 px-4 py-2 text-sm font-medium text-red-300 hover:bg-red-500/15 transition-colors">
                  Error
                </button>
              </div>

              <!-- Viewport de toasts dentro do preview -->
              <div id="toast-viewport" class="absolute bottom-4 right-4 flex flex-col gap-2 w-[300px] pointer-events-none z-50"></div>
            </div>
            <p class="text-xs text-foreground/30">Clique para disparar — fecha automaticamente em 3 s ou manualmente. Em produção usa <code class="font-mono text-primary/70">useToast()</code> + Radix ToastProvider.</p>

            <div>
              <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-4">Anatomia</p>
              <div class="rounded-xl border border-border/10 bg-card/30 p-8 space-y-3 max-w-sm">
                <div class="pointer-events-auto relative flex w-full items-start gap-3 overflow-hidden rounded-lg border border-border/18 bg-card p-4 shadow-lg">
                  <div class="flex-1 space-y-1">
                    <p class="text-sm font-medium leading-snug text-foreground/90">Título do toast</p>
                    <p class="text-xs opacity-70 leading-relaxed text-foreground/80">Descrição opcional com detalhes adicionais.</p>
                  </div>
                  <button class="ml-auto shrink-0 rounded opacity-40 hover:opacity-100 transition-opacity">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    <span class="sr-only">Fechar</span>
                  </button>
                </div>
                <div class="pointer-events-auto relative flex w-full items-start gap-3 overflow-hidden rounded-lg border border-emerald-500/30 bg-emerald-500/10 p-4 shadow-lg">
                  <div class="flex-1 space-y-1">
                    <p class="text-sm font-medium leading-snug text-emerald-200">Projeto publicado</p>
                    <p class="text-xs opacity-70 leading-relaxed text-emerald-200">Deploy concluído em 12 s.</p>
                  </div>
                  <button class="ml-auto shrink-0 rounded opacity-40 hover:opacity-100 transition-opacity text-emerald-200">
                    <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
                    <span class="sr-only">Fechar</span>
                  </button>
                </div>
              </div>
            </div>
          </div>
        )}

      </div>
    )}

    <!-- Em construção -->
    {!component.hasDemo && (
      <div class="rounded-2xl border border-border/10 bg-card/20 px-8 py-12 text-center">
        <div class="w-12 h-12 rounded-xl bg-primary/8 flex items-center justify-center mx-auto mb-4 text-primary/40">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/>
          </svg>
        </div>
        <p class="text-sm font-semibold text-foreground/50 mb-2">Em construção — Fase 4</p>
        <p class="text-xs text-foreground/30 max-w-xs mx-auto">
          Demo e documentação chegam na próxima sprint. O componente já está planejado e será instalável via registry.
        </p>
      </div>
    )}

    <!-- Props table -->
    {component.props && component.props.length > 0 && (
      <div>
        <h2 class="text-h3 text-foreground/80 mb-4">Props</h2>
        <div class="rounded-xl border border-border/10 overflow-hidden">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-border/10 bg-card/40">
                <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-widest text-foreground/30 w-32">Prop</th>
                <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-widest text-foreground/30">Tipo</th>
                <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-widest text-foreground/30 w-28 hidden sm:table-cell">Default</th>
                <th class="text-left px-4 py-3 text-xs font-semibold uppercase tracking-widest text-foreground/30">Descrição</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-border/10">
              {component.props.map(prop => (
                <tr class="hover:bg-card/20 transition-colors">
                  <td class="px-4 py-3">
                    <code class="text-xs font-mono font-semibold text-primary/80">{prop.name}</code>
                  </td>
                  <td class="px-4 py-3">
                    <code class="text-xs font-mono text-foreground/40">{prop.type}</code>
                  </td>
                  <td class="px-4 py-3 hidden sm:table-cell">
                    {prop.default
                      ? <code class="text-xs font-mono text-foreground/35">{prop.default}</code>
                      : <span class="text-xs text-foreground/20">—</span>
                    }
                  </td>
                  <td class="px-4 py-3 text-xs text-foreground/45">{prop.desc}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </div>
    )}

  </div>

  <script define:vars={{ slug: component.slug }}>
    // Copy button
    const btn = document.getElementById("copy-btn");
    const iconCopy = document.getElementById("icon-copy");
    const iconCheck = document.getElementById("icon-check");

    btn?.addEventListener("click", () => {
      navigator.clipboard.writeText(`npx shadcn add @studio/${slug}`).then(() => {
        iconCopy?.classList.add("hidden");
        iconCheck?.classList.remove("hidden");
        setTimeout(() => {
          iconCopy?.classList.remove("hidden");
          iconCheck?.classList.add("hidden");
        }, 1800);
      });
    });

    // Tabs demo interactivity
    const triggers = document.querySelectorAll("[data-tab-trigger]");
    const panels   = document.querySelectorAll("[data-tab-panel]");

    triggers.forEach(trigger => {
      trigger.addEventListener("click", () => {
        const target = trigger.dataset.tabTrigger;

        triggers.forEach(t => {
          const isActive = t.dataset.tabTrigger === target;
          t.classList.toggle("bg-background",    isActive);
          t.classList.toggle("text-foreground/90", isActive);
          t.classList.toggle("shadow-sm",          isActive);
          t.classList.toggle("text-foreground/50", !isActive);
        });

        panels.forEach(panel => {
          panel.classList.toggle("hidden", panel.dataset.tabPanel !== target);
        });
      });
    });

    // Accordion demo interactivity
    document.querySelectorAll("[data-accordion-trigger]").forEach(btn => {
      btn.addEventListener("click", () => {
        const id      = btn.dataset.accordionTrigger;
        const content = document.querySelector(`[data-accordion-content="${id}"]`);
        const chevron = document.querySelector(`[data-chevron="${id}"]`);
        const isOpen  = !content.classList.contains("hidden");
        // fecha todos
        document.querySelectorAll("[data-accordion-content]").forEach(c => c.classList.add("hidden"));
        document.querySelectorAll("[data-accordion-trigger]").forEach(b => b.setAttribute("aria-expanded", "false"));
        document.querySelectorAll("[data-chevron]").forEach(ch => ch.classList.remove("rotate-180"));
        // abre o clicado (se estava fechado)
        if (!isOpen) {
          content.classList.remove("hidden");
          btn.setAttribute("aria-expanded", "true");
          chevron?.classList.add("rotate-180");
        }
      });
    });

    // Checkbox demo interactivity
    document.querySelectorAll("[data-checkbox]").forEach(label => {
      if (label.dataset.disabled) return;
      label.addEventListener("click", () => {
        const isChecked = label.dataset.checked === "true";
        label.dataset.checked = isChecked ? "false" : "true";
        const box  = label.querySelector(".cb-box");
        const mark = label.querySelector(".cb-mark");
        if (isChecked) {
          box.classList.remove("bg-primary", "border-primary", "text-primary-foreground");
          box.classList.add("border-border/30", "bg-background/60");
          mark.classList.add("hidden");
        } else {
          box.classList.add("bg-primary", "border-primary", "text-primary-foreground");
          box.classList.remove("border-border/30", "bg-background/60");
          mark.classList.remove("hidden");
        }
      });
    });

    // Radio demo interactivity
    document.querySelectorAll("[data-radio-item]").forEach(label => {
      label.addEventListener("click", () => {
        document.querySelectorAll("[data-radio-item]").forEach(l => {
          const circle = l.querySelector(".ri-circle");
          const dot    = l.querySelector(".ri-dot");
          l.dataset.selected = "false";
          circle.classList.remove("border-primary");
          circle.classList.add("border-border/30");
          dot.classList.remove("scale-100");
          dot.classList.add("scale-0");
        });
        const circle = label.querySelector(".ri-circle");
        const dot    = label.querySelector(".ri-dot");
        label.dataset.selected = "true";
        circle.classList.add("border-primary");
        circle.classList.remove("border-border/30");
        dot.classList.add("scale-100");
        dot.classList.remove("scale-0");
      });
    });

    // Select demo interactivity
    const selectTrigger  = document.getElementById("select-trigger");
    const selectDropdown = document.getElementById("select-dropdown");
    const selectValue    = document.getElementById("select-value");
    const selectChevron  = document.getElementById("select-chevron");

    selectTrigger?.addEventListener("click", () => {
      const isOpen = selectDropdown.classList.toggle("hidden") === false;
      selectTrigger.setAttribute("aria-expanded", String(isOpen));
      selectChevron?.classList.toggle("rotate-180", isOpen);
    });

    document.querySelectorAll(".select-item").forEach(item => {
      item.addEventListener("click", () => {
        const val = item.dataset.selectItem;
        if (selectValue) selectValue.innerHTML = val;
        document.querySelectorAll(".select-check").forEach(c => c.classList.add("hidden"));
        item.querySelector(".select-check")?.classList.remove("hidden");
        selectDropdown.classList.add("hidden");
        selectTrigger?.setAttribute("aria-expanded", "false");
        selectChevron?.classList.remove("rotate-180");
      });
    });

    // Fecha select ao clicar fora
    document.addEventListener("click", e => {
      if (selectTrigger && !selectTrigger.contains(e.target) && !selectDropdown?.contains(e.target)) {
        selectDropdown?.classList.add("hidden");
        selectTrigger.setAttribute("aria-expanded", "false");
        selectChevron?.classList.remove("rotate-180");
      }
    });

    // Drawer demo interactivity
    const drawerOpenBtn  = document.getElementById("drawer-open-btn");
    const drawerPanel    = document.getElementById("drawer-panel");
    const drawerOverlay  = document.getElementById("drawer-overlay");
    const drawerCloseBtn = document.getElementById("drawer-close-btn");
    const drawerCancelBtn = document.getElementById("drawer-cancel-btn");
    const drawerConfirmBtn = document.getElementById("drawer-confirm-btn");

    const openDrawer = () => {
      drawerOverlay?.classList.remove("hidden");
      drawerPanel?.classList.remove("translate-x-full");
      document.body.style.overflow = "hidden";
    };

    const closeDrawer = () => {
      drawerPanel?.classList.add("translate-x-full");
      setTimeout(() => drawerOverlay?.classList.add("hidden"), 300);
      document.body.style.overflow = "";
    };

    drawerOpenBtn?.addEventListener("click", openDrawer);
    drawerCloseBtn?.addEventListener("click", closeDrawer);
    drawerCancelBtn?.addEventListener("click", closeDrawer);
    drawerConfirmBtn?.addEventListener("click", closeDrawer);
    drawerOverlay?.addEventListener("click", closeDrawer);

    // Dropdown demo interactivity
    const ddTrigger  = document.getElementById("dropdown-trigger");
    const ddMenu     = document.getElementById("dropdown-menu");
    const ddChevron  = document.getElementById("dropdown-chevron");

    ddTrigger?.addEventListener("click", () => {
      const isOpen = ddMenu.classList.toggle("hidden") === false;
      ddTrigger.setAttribute("aria-expanded", String(isOpen));
      ddChevron?.classList.toggle("rotate-180", isOpen);
    });

    document.addEventListener("click", e => {
      if (ddTrigger && !ddTrigger.contains(e.target) && !ddMenu?.contains(e.target)) {
        ddMenu?.classList.add("hidden");
        ddTrigger.setAttribute("aria-expanded", "false");
        ddChevron?.classList.remove("rotate-180");
      }
    });

    ddMenu?.querySelectorAll("[role=menuitem]").forEach(item => {
      item.addEventListener("click", () => {
        ddMenu.classList.add("hidden");
        ddTrigger?.setAttribute("aria-expanded", "false");
        ddChevron?.classList.remove("rotate-180");
      });
    });

    // Pagination demo interactivity
    const pgDemo = document.getElementById("pagination-demo");
    if (pgDemo) {
      const totalPages = 5;
      let currentPage = 3;

      const updatePagination = () => {
        pgDemo.querySelectorAll("[data-pg]").forEach(link => {
          const n = Number(link.dataset.pg);
          const active = n === currentPage;
          link.setAttribute("aria-current", active ? "page" : "false");
          link.className = `inline-flex h-9 min-w-9 items-center justify-center rounded-lg border text-sm font-medium transition-colors ${
            active
              ? "border-primary/40 bg-primary/10 text-primary pointer-events-none"
              : "border-transparent text-foreground/55 hover:border-border/20 hover:bg-card/50 hover:text-foreground/85"
          }`;
        });
        const prevLink = pgDemo.querySelector("[data-pg-prev]");
        const nextLink = pgDemo.querySelector("[data-pg-next]");
        if (prevLink) prevLink.style.opacity = currentPage === 1 ? "0.3" : "1";
        if (nextLink) nextLink.style.opacity = currentPage === totalPages ? "0.3" : "1";
      };

      pgDemo.querySelectorAll("[data-pg]").forEach(link => {
        link.addEventListener("click", e => {
          e.preventDefault();
          currentPage = Number(link.dataset.pg);
          updatePagination();
        });
      });

      pgDemo.querySelector("[data-pg-prev]")?.addEventListener("click", e => {
        e.preventDefault();
        if (currentPage > 1) { currentPage--; updatePagination(); }
      });

      pgDemo.querySelector("[data-pg-next]")?.addEventListener("click", e => {
        e.preventDefault();
        if (currentPage < totalPages) { currentPage++; updatePagination(); }
      });

      updatePagination();
    }

    // Toast demo
    const toastViewport = document.getElementById("toast-viewport");
    const toastConfig = {
      default: { title: "Notificação",       desc: "Isso é uma mensagem padrão.",           cls: "border-border/18 bg-card text-foreground/80" },
      success: { title: "Sucesso",           desc: "Operação concluída com êxito.",          cls: "border-emerald-500/30 bg-emerald-500/10 text-emerald-200" },
      warning: { title: "Atenção",           desc: "Verifique antes de prosseguir.",         cls: "border-amber-500/30 bg-amber-500/10 text-amber-200" },
      error:   { title: "Erro",              desc: "Algo deu errado. Tente novamente.",      cls: "border-red-500/30 bg-red-500/10 text-red-200" },
    };

    document.querySelectorAll("[data-toast-trigger]").forEach(btn => {
      btn.addEventListener("click", () => {
        if (!toastViewport) return;
        const variant = btn.dataset.toastTrigger;
        const cfg = toastConfig[variant] || toastConfig.default;

        const el = document.createElement("div");
        el.className = `pointer-events-auto relative flex w-full items-start gap-3 overflow-hidden rounded-lg border p-4 shadow-lg transition-all duration-300 opacity-0 translate-y-2 ${cfg.cls}`;
        el.innerHTML = `
          <div class="flex-1 space-y-1">
            <p class="text-sm font-medium leading-snug">${cfg.title}</p>
            <p class="text-xs opacity-70 leading-relaxed">${cfg.desc}</p>
          </div>
          <button class="toast-close ml-auto shrink-0 rounded opacity-40 hover:opacity-100 transition-opacity">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>`;

        toastViewport.prepend(el);
        requestAnimationFrame(() => {
          el.classList.remove("opacity-0", "translate-y-2");
        });

        const dismiss = () => {
          el.classList.add("opacity-0", "translate-y-2");
          setTimeout(() => el.remove(), 300);
        };
        el.querySelector(".toast-close").addEventListener("click", dismiss);
        setTimeout(dismiss, 3000);
      });
    });
  </script>
</StyleguideLayout>
