---
import Base from "../layouts/Base.astro";
---

<Base title="Brand">
  <main class="px-6 py-16">
    <div class="mx-auto max-w-5xl">

      <!-- Cabeçalho -->
      <div class="mb-16">
        <span class="inline-flex items-center rounded-full px-3 py-0.5 text-xs font-medium bg-accent/20 border border-accent/30 text-foreground/90 mb-4">
          Brand Guide
        </span>
        <h1 class="text-3xl md:text-4xl font-extrabold text-foreground/90 mb-3">
          Identidade visual
        </h1>
        <p class="text-base text-foreground/50 max-w-xl leading-relaxed">
          Paleta, tipografia, radius e sombras do Studio. Use como referência durante o briefing de marca com o cliente — mostre as opções antes de fechar o projeto.
        </p>
      </div>

      <!-- ── 1. Paleta ─────────────────────────────────────────── -->
      <section class="mb-20">
        <h2 class="text-base font-bold text-foreground/90 mb-1 uppercase tracking-widest text-xs text-foreground/40">01</h2>
        <h3 class="text-xl font-bold text-foreground/90 mb-6">Paleta de cores</h3>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
          <div>
            <div class="h-20 rounded-lg bg-background border border-white/5 mb-2 shadow-card"></div>
            <p class="text-xs font-mono text-foreground/70">background</p>
            <p class="text-xs text-foreground/35 mt-0.5">#081424</p>
          </div>
          <div>
            <div class="h-20 rounded-lg border border-white/5 mb-2 shadow-card" style="background: rgb(var(--background-secondary))"></div>
            <p class="text-xs font-mono text-foreground/70">bg-secondary</p>
            <p class="text-xs text-foreground/35 mt-0.5">#030C17</p>
          </div>
          <div>
            <div class="h-20 rounded-lg bg-card border border-white/5 mb-2 shadow-card"></div>
            <p class="text-xs font-mono text-foreground/70">card</p>
            <p class="text-xs text-foreground/35 mt-0.5">#081424</p>
          </div>
          <div>
            <div class="h-20 rounded-lg bg-primary mb-2 shadow-glow"></div>
            <p class="text-xs font-mono text-foreground/70">primary</p>
            <p class="text-xs text-foreground/35 mt-0.5">#00ADCF</p>
          </div>
          <div>
            <div class="h-20 rounded-lg border border-white/5 mb-2" style="background: rgb(232 244 251 / 0.92)"></div>
            <p class="text-xs font-mono text-foreground/70">foreground</p>
            <p class="text-xs text-foreground/35 mt-0.5">rgba(232,244,251,0.92)</p>
          </div>
          <div>
            <div class="h-20 rounded-lg bg-destructive mb-2"></div>
            <p class="text-xs font-mono text-foreground/70">destructive</p>
            <p class="text-xs text-foreground/35 mt-0.5">#EF4444</p>
          </div>
        </div>

        <!-- Acento primário — exemplos para clientes -->
        <p class="text-xs text-foreground/40 uppercase tracking-widest mb-4 font-semibold">Exemplos de acento por segmento</p>
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
          <div class="rounded-lg border border-accent/30 bg-accent/5 p-4 ring-1 ring-accent/20">
            <div class="h-2 w-12 rounded-full bg-primary mb-3"></div>
            <p class="text-sm font-semibold text-foreground/80">Studio cyan</p>
            <p class="text-xs font-mono text-foreground/40 mt-1">#00ADCF — 0 173 207</p>
            <p class="text-xs text-foreground/30 mt-0.5">Padrão do kit</p>
          </div>
          <div class="rounded-lg border border-border/15 bg-background-secondary/40 p-4">
            <div class="h-2 w-12 rounded-full mb-3" style="background:#FF5733"></div>
            <p class="text-sm font-semibold text-foreground/80">Laranja</p>
            <p class="text-xs font-mono text-foreground/40 mt-1">#FF5733 — 255 87 51</p>
            <p class="text-xs text-foreground/30 mt-0.5">Nutrição, esporte, energia</p>
          </div>
          <div class="rounded-lg border border-border/15 bg-background-secondary/40 p-4">
            <div class="h-2 w-12 rounded-full mb-3" style="background:#7C5CBF"></div>
            <p class="text-sm font-semibold text-foreground/80">Roxo</p>
            <p class="text-xs font-mono text-foreground/40 mt-1">#7C5CBF — 124 92 191</p>
            <p class="text-xs text-foreground/30 mt-0.5">Terapia, bem-estar, holístico</p>
          </div>
        </div>
      </section>

      <!-- ── 2. Tipografia ──────────────────────────────────────── -->
      <section class="mb-20">
        <h2 class="text-xs font-bold text-foreground/40 uppercase tracking-widest mb-1">02</h2>
        <h3 class="text-xl font-bold text-foreground/90 mb-6">Tipografia — Manrope</h3>

        <div class="rounded-xl border border-border/10 bg-background-secondary/40 divide-y divide-border/10 overflow-hidden">
          <div class="flex items-baseline gap-6 px-6 py-5">
            <span class="text-xs text-foreground/35 font-mono w-28 shrink-0">text-6xl · 800</span>
            <span class="text-6xl font-extrabold text-foreground/90 leading-none">Display</span>
          </div>
          <div class="flex items-baseline gap-6 px-6 py-5">
            <span class="text-xs text-foreground/35 font-mono w-28 shrink-0">text-4xl · 700</span>
            <span class="text-4xl font-bold text-foreground/90 leading-tight">Heading 1</span>
          </div>
          <div class="flex items-baseline gap-6 px-6 py-5">
            <span class="text-xs text-foreground/35 font-mono w-28 shrink-0">text-2xl · 700</span>
            <span class="text-2xl font-bold text-foreground/90">Heading 2</span>
          </div>
          <div class="flex items-baseline gap-6 px-6 py-5">
            <span class="text-xs text-foreground/35 font-mono w-28 shrink-0">text-xl · 600</span>
            <span class="text-xl font-semibold text-foreground/90">Heading 3</span>
          </div>
          <div class="flex items-baseline gap-6 px-6 py-5">
            <span class="text-xs text-foreground/35 font-mono w-28 shrink-0 mt-1">text-base · 400</span>
            <span class="text-base text-foreground/70 leading-relaxed max-w-xl">Corpo de texto. O Studio trabalha com clareza, intenção e elegância — cada palavra no lugar certo, cada detalhe justificado.</span>
          </div>
          <div class="flex items-baseline gap-6 px-6 py-5">
            <span class="text-xs text-foreground/35 font-mono w-28 shrink-0">text-sm · 500</span>
            <span class="text-sm font-medium text-foreground/60">Label · UI text · Categoria</span>
          </div>
          <div class="flex items-baseline gap-6 px-6 py-5">
            <span class="text-xs text-foreground/35 font-mono w-28 shrink-0">text-xs · mono</span>
            <span class="text-xs font-mono text-foreground/40">npx shadcn@latest add button.json --yes</span>
          </div>
        </div>

        <p class="text-xs text-foreground/35 mt-4 font-mono">
          @import url('fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap')
        </p>
      </section>

      <!-- ── 3. Radius ──────────────────────────────────────────── -->
      <section class="mb-20">
        <h2 class="text-xs font-bold text-foreground/40 uppercase tracking-widest mb-1">03</h2>
        <h3 class="text-xl font-bold text-foreground/90 mb-2">Radius</h3>
        <p class="text-sm text-foreground/50 mb-6">
          Controla a personalidade dos cantos. Ajuste <code class="bg-accent/10 px-1.5 py-0.5 rounded text-xs font-mono text-primary">--radius</code> em <code class="bg-accent/10 px-1.5 py-0.5 rounded text-xs font-mono text-primary">tokens.css</code>.
        </p>

        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <!-- Rígido -->
          <div class="border border-border/15 bg-background-secondary/40 p-6 text-center" style="border-radius:0">
            <div class="h-14 w-full border border-border/20 bg-accent/10 mb-5" style="border-radius:0"></div>
            <p class="text-sm font-semibold text-foreground/80 mb-1">Rígido</p>
            <p class="text-xs font-mono text-foreground/40 mb-1">--radius: 0rem</p>
            <p class="text-xs text-foreground/30">Institucional, corporativo</p>
          </div>
          <!-- Studio padrão -->
          <div class="rounded-lg border border-accent/30 bg-background-secondary/40 p-6 text-center ring-1 ring-accent/20">
            <div class="h-14 w-full rounded-lg border border-border/20 bg-accent/15 mb-5"></div>
            <p class="text-sm font-semibold text-primary mb-1">Studio · padrão</p>
            <p class="text-xs font-mono text-foreground/40 mb-1">--radius: 0.5rem</p>
            <p class="text-xs text-foreground/30">Contemporâneo, premium</p>
          </div>
          <!-- Amigável -->
          <div class="rounded-2xl border border-border/15 bg-background-secondary/40 p-6 text-center">
            <div class="h-14 w-full rounded-2xl border border-border/20 bg-accent/10 mb-5"></div>
            <p class="text-sm font-semibold text-foreground/80 mb-1">Amigável</p>
            <p class="text-xs font-mono text-foreground/40 mb-1">--radius: 1rem</p>
            <p class="text-xs text-foreground/30">Saúde, bem-estar, educação</p>
          </div>
        </div>
      </section>

      <!-- ── 4. Sombras ─────────────────────────────────────────── -->
      <section class="mb-20">
        <h2 class="text-xs font-bold text-foreground/40 uppercase tracking-widest mb-1">04</h2>
        <h3 class="text-xl font-bold text-foreground/90 mb-6">Sombras</h3>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
          <div>
            <div class="h-24 rounded-lg bg-card shadow-hero border border-border/10 mb-3"></div>
            <p class="text-xs font-mono text-foreground/70">shadow-hero</p>
            <p class="text-xs text-foreground/35 mt-0.5">Seções de destaque</p>
          </div>
          <div>
            <div class="h-24 rounded-lg bg-card shadow-card border border-border/10 mb-3"></div>
            <p class="text-xs font-mono text-foreground/70">shadow-card</p>
            <p class="text-xs text-foreground/35 mt-0.5">Cards e containers</p>
          </div>
          <div>
            <div class="h-24 rounded-lg bg-card shadow-metric border border-border/10 mb-3"></div>
            <p class="text-xs font-mono text-foreground/70">shadow-metric</p>
            <p class="text-xs text-foreground/35 mt-0.5">Blocos de métricas</p>
          </div>
          <div>
            <div class="h-24 rounded-lg bg-card shadow-glow border border-border/10 mb-3"></div>
            <p class="text-xs font-mono text-foreground/70">shadow-glow</p>
            <p class="text-xs text-foreground/35 mt-0.5">CTA / destaque primário</p>
          </div>
        </div>
      </section>

      <!-- ── 5. Componentes — prévia ────────────────────────────── -->
      <section>
        <h2 class="text-xs font-bold text-foreground/40 uppercase tracking-widest mb-1">05</h2>
        <h3 class="text-xl font-bold text-foreground/90 mb-6">Componentes — prévia</h3>

        <div class="rounded-xl border border-border/10 bg-background-secondary/40 p-6 flex flex-wrap gap-3 items-center">
          <!-- Button variants -->
          <button class="inline-flex items-center justify-center rounded-lg px-5 py-2 text-sm font-medium bg-primary text-primary-foreground hover:bg-primary/90 transition-colors">
            Primary
          </button>
          <button class="inline-flex items-center justify-center rounded-lg px-5 py-2 text-sm font-medium bg-accent/20 border border-accent/40 text-foreground/90 hover:bg-accent/30 transition-colors">
            Default
          </button>
          <button class="inline-flex items-center justify-center rounded-lg px-5 py-2 text-sm font-medium border border-border/25 bg-transparent hover:bg-accent/10 text-foreground/80 transition-colors">
            Outline
          </button>
          <button class="inline-flex items-center justify-center rounded-lg px-5 py-2 text-sm font-medium hover:bg-accent/10 text-foreground/70 transition-colors">
            Ghost
          </button>

          <!-- Badges -->
          <span class="inline-flex items-center rounded-full px-3 py-0.5 text-xs font-medium bg-accent/20 border border-accent/30 text-foreground/90">
            Badge accent
          </span>
          <span class="inline-flex items-center rounded-full px-3 py-0.5 text-xs font-medium bg-primary/15 border border-primary/30 text-primary">
            Badge primary
          </span>

          <!-- Input -->
          <input
            type="text"
            placeholder="Campo de texto"
            class="h-10 rounded-lg border border-border/25 bg-background px-4 text-sm text-foreground/80 placeholder:text-foreground/35 focus:outline-none focus:ring-2 focus:ring-ring/40 w-48"
          />
        </div>

        <p class="text-xs text-foreground/35 mt-4">
          Instale via <code class="font-mono">npx shadcn@latest add "https://kit.carloshps.com.br/registry/button.json"</code>
        </p>
      </section>

    </div>
  </main>
</Base>
