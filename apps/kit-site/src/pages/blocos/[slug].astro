---
import StyleguideLayout from "../../layouts/StyleguideLayout.astro";

export function getStaticPaths() {
  return blocks.map(b => ({ params: { slug: b.slug } }));
}

interface BlockDef {
  slug: string
  name: string
  description: string
  hasDemo: boolean
  source?: string
  props?: { name: string; type: string; default?: string; desc: string }[]
}

const blocks: BlockDef[] = [
  {
    slug: "hero",
    name: "Hero",
    hasDemo: true,
    source: "@studio/hero",
    description: "Seção de abertura da página. Suporta eyebrow (Badge), título com destaque colorido, subtítulo e dois CTAs.",
    props: [
      { name: "eyebrow",        type: "string",                          desc: "Texto do badge acima do título" },
      { name: "title",          type: "string",                          desc: "Título principal (obrigatório)" },
      { name: "titleHighlight", type: "string",                          desc: "Trecho do título em cor primária" },
      { name: "subtitle",       type: "string",                          desc: "Parágrafo de suporte abaixo do título" },
      { name: "primaryCta",     type: "{ label: string; href: string }", desc: "Botão de ação principal" },
      { name: "secondaryCta",   type: "{ label: string; href: string }", desc: "Botão de ação secundário (outline)" },
      { name: "className",      type: "string",                          desc: "Classes adicionais para o section" },
    ],
  },
  {
    slug: "cta",
    name: "CTA Section",
    hasDemo: true,
    source: "@studio/cta-section",
    description: "Seção de chamada para ação. Container com borda accent, fundo gradiente e sombra hero. Suporta CTA primário e secundário.",
    props: [
      { name: "title",        type: "string",                          desc: "Título da CTA (obrigatório)" },
      { name: "subtitle",     type: "string",                          desc: "Texto de suporte (opcional)" },
      { name: "cta",          type: "{ label: string; href: string }", desc: "Botão primário (obrigatório)" },
      { name: "secondaryCta", type: "{ label: string; href: string }", desc: "Botão secundário (opcional)" },
      { name: "className",    type: "string",                          desc: "Classes adicionais" },
    ],
  },
  {
    slug: "pricing",
    name: "Pricing Card",
    hasDemo: true,
    source: "@studio/pricing-card",
    description: "Card de plano e preço. Suporta highlight (destaque com borda e sombra hero), badge, lista de features e CTA adaptado ao nível de ênfase.",
    props: [
      { name: "name",        type: "string",                          desc: "Nome do plano" },
      { name: "price",       type: "string",                          desc: "Valor (ex: 'R$1.200')" },
      { name: "period",      type: "string",        default: "único", desc: "Periodicidade (ex: '/mês')" },
      { name: "description", type: "string",                          desc: "Descrição breve do plano" },
      { name: "features",    type: "string[]",                        desc: "Lista de inclusões" },
      { name: "cta",         type: "{ label: string; href: string }", desc: "Botão de ação" },
      { name: "highlight",   type: "boolean",       default: "false", desc: "Destaque visual (borda + sombra hero)" },
      { name: "badge",       type: "string",                          desc: "Badge de destaque (ex: 'Recomendado')" },
    ],
  },
  {
    slug: "faq",
    name: "FAQ",
    hasDemo: true,
    source: "@studio/faq",
    description: "Accordion de perguntas frequentes com estado React. Suporta título customizável e lista de itens pergunta/resposta.",
    props: [
      { name: "title",     type: "string",       default: "Perguntas frequentes", desc: "Título da seção" },
      { name: "items",     type: "FaqItem[]",                                      desc: "Array de { question, answer }" },
      { name: "className", type: "string",                                         desc: "Classes adicionais" },
    ],
  },
  {
    slug: "testimonial",
    name: "Testimonial",
    hasDemo: true,
    source: "@studio/testimonial",
    description: "Grid de depoimentos. Cada item tem citação, nome, cargo e avatar (com fallback para inicial). Layout responsivo 1→2→3 colunas.",
    props: [
      { name: "items",     type: "TestimonialItem[]", desc: "Array de { quote, author, role?, avatar? }" },
      { name: "className", type: "string",            desc: "Classes adicionais" },
    ],
  },
  {
    slug: "lead-form",
    name: "Lead Form",
    hasDemo: true,
    source: "@studio/lead-form",
    description: "Formulário de captação com nome, e-mail, WhatsApp e mensagem. Gerencia estado loading/success/error internamente. POST para endpoint customizável.",
    props: [
      { name: "apiEndpoint",     type: "string",                desc: "URL para onde o form faz POST (obrigatório)" },
      { name: "title",           type: "string",                desc: "Título acima do form" },
      { name: "subtitle",        type: "string",                desc: "Subtítulo de suporte" },
      { name: "ctaLabel",        type: "string", default: "Quero começar",                      desc: "Texto do botão de envio" },
      { name: "successMessage",  type: "string", default: "Recebemos seu contato. Retorno em breve.", desc: "Mensagem após envio bem-sucedido" },
    ],
  },
  {
    slug: "metric-block",
    name: "Metric Block",
    hasDemo: true,
    source: "@studio/metric-block",
    description: "Card de métrica individual. Valor grande em primário com glow, label em destaque e descrição opcional. Compõe bem em grid 2×2 ou 4 colunas.",
    props: [
      { name: "value",       type: "string", desc: "Número ou texto da métrica (ex: '98%')" },
      { name: "label",       type: "string", desc: "Nome da métrica" },
      { name: "description", type: "string", desc: "Contexto adicional (opcional)" },
      { name: "className",   type: "string", desc: "Classes adicionais" },
    ],
  },
  {
    slug: "footer",
    name: "Footer",
    hasDemo: true,
    source: "@studio/footer",
    description: "Rodapé com brand (nome + tagline), colunas de links e barra de copyright. Fundo background-secondary, borda sutil no topo.",
    props: [
      { name: "brand",     type: "{ name: string; tagline?: string }",   desc: "Identidade da marca" },
      { name: "columns",   type: "FooterColumn[]",   default: "[]",      desc: "Colunas de links { title, links[] }" },
      { name: "legal",     type: "string",                               desc: "Texto de política/direitos (opcional)" },
      { name: "className", type: "string",                               desc: "Classes adicionais" },
    ],
  },
  {
    slug: "modal",
    name: "Modal",
    hasDemo: true,
    source: "@studio/modal",
    description: "Janela modal genérica baseada em Dialog (Radix). Overlay escurecido com blur, fechar ao clicar fora ou tecla Esc, foco preso e gerenciado automaticamente. Acessível por padrão.",
    props: [
      { name: "title",        type: "string",                       desc: "Título no topo do modal (obrigatório)" },
      { name: "triggerLabel", type: "string",                       desc: "Texto do botão que abre o modal" },
      { name: "description",  type: "string",                       desc: "Texto de apoio abaixo do título" },
      { name: "children",     type: "ReactNode",                    desc: "Conteúdo do corpo do modal" },
      { name: "confirmLabel", type: "string",                       desc: "Texto do botão de confirmação (omita para esconder)" },
      { name: "cancelLabel",  type: "string", default: "Cancelar",  desc: "Texto do botão de cancelar" },
      { name: "onConfirm",    type: "() => void",                   desc: "Callback ao confirmar" },
      { name: "open",         type: "boolean",                      desc: "Estado controlado de abertura (opcional)" },
      { name: "onOpenChange", type: "(open: boolean) => void",      desc: "Handler de mudança quando controlado" },
      { name: "className",    type: "string",                       desc: "Classes adicionais para o conteúdo" },
    ],
  },
  {
    slug: "login",
    name: "Login",
    hasDemo: true,
    source: "@studio/login",
    description: "Tela de autenticação. Card centralizado com campos de e-mail e senha, botão de acesso e link de recuperação. Gerencia estado de loading internamente quando onSubmit devolve uma Promise.",
    props: [
      { name: "title",      type: "string",   default: "Acesse sua conta", desc: "Título do card" },
      { name: "subtitle",   type: "string",                                desc: "Texto de apoio abaixo do título" },
      { name: "ctaLabel",   type: "string",   default: "Entrar",           desc: "Texto do botão de submit" },
      { name: "forgotHref", type: "string",                                desc: "Link de recuperação de senha (omita para esconder)" },
      { name: "footer",     type: "ReactNode",                             desc: "Rodapé (ex: link de cadastro)" },
      { name: "onSubmit",   type: "(data) => void | Promise<void>",        desc: "Callback de envio com { email, password }" },
      { name: "className",  type: "string",                                desc: "Classes adicionais" },
    ],
  },
];

const { slug } = Astro.params;
const block = blocks.find(b => b.slug === slug);

if (!block) {
  return Astro.redirect("/blocos");
}
---

<StyleguideLayout title={block.name}>
  <div class="px-8 py-12 max-w-container mx-auto space-y-12">

    <!-- Cabeçalho -->
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-foreground/30 mb-2">Bloco</p>
      <div class="flex items-start justify-between gap-4 flex-wrap">
        <div>
          <h1 class="text-h1 text-foreground/90 mb-2">{block.name}</h1>
          <p class="text-body text-foreground/50 max-w-2xl">{block.description}</p>
        </div>
        {!block.hasDemo && (
          <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/20 bg-primary/8 px-3 py-1 text-xs font-semibold text-primary/80 shrink-0">
            Em construção
          </span>
        )}
      </div>

      <!-- Install command -->
      {block.source && (
        <div class="mt-4 flex items-center gap-2 rounded-lg border border-border/10 bg-card/40 px-4 py-2.5 w-fit">
          <svg class="text-foreground/25 shrink-0" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
          </svg>
          <code class="text-xs font-mono text-foreground/55">
            npx shadcn add {block.source}
          </code>
          <button id="copy-btn" aria-label="Copiar comando" class="ml-1 p-1 rounded text-foreground/30 hover:text-primary transition-colors">
            <svg id="icon-copy" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
            </svg>
            <svg id="icon-check" class="hidden" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"/>
            </svg>
          </button>
        </div>
      )}
    </div>

    <!-- ── Demos ──────────────────────────────────────────────────────── -->
    {block.hasDemo && (
      <div class="space-y-8">

        <!-- HERO demo -->
        {block.slug === "hero" && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-4">Preview</p>
            <div class="rounded-xl border border-border/10 overflow-hidden">
              <section class="relative flex flex-col items-center justify-center text-center px-6 py-16 bg-background shadow-hero">
                <!-- Glow -->
                <div class="pointer-events-none absolute inset-0 flex items-center justify-center">
                  <div class="h-64 w-96 rounded-full bg-primary/5 blur-[80px]"></div>
                </div>
                <div class="relative flex flex-col items-center">
                  <span class="mb-6 inline-flex items-center rounded-full px-3 py-0.5 text-xs font-medium bg-accent/20 border border-accent/30 text-foreground/90">
                    Saúde e bem-estar
                  </span>
                  <h1 class="max-w-2xl text-3xl sm:text-4xl font-extrabold leading-tight text-foreground/90">
                    Sua presença digital com
                    <span class="hl"> direção e resultado</span>
                  </h1>
                  <p class="mt-4 max-w-lg text-base text-foreground/50 leading-relaxed">
                    Presença profissional para profissionais de saúde e bem-estar que querem ser encontrados e lembrados.
                  </p>
                  <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
                    <a href="#" class="inline-flex items-center justify-center gap-2 rounded-lg text-sm font-medium h-11 px-6 bg-primary text-primary-foreground hover:bg-primary/90 transition-opacity">
                      Quero começar
                    </a>
                    <a href="#" class="inline-flex items-center justify-center gap-2 rounded-lg text-sm font-medium h-11 px-6 border border-border/25 bg-transparent text-foreground/70 hover:border-primary/30 transition-colors">
                      Ver cases
                    </a>
                  </div>
                </div>
              </section>
              <div class="bg-card/20 px-6 py-3 text-center">
                <p class="text-xs text-foreground/30">Hero — eyebrow, título com highlight, subtitle, dual CTA</p>
              </div>
            </div>
          </div>
        )}

        <!-- CTA demo -->
        {block.slug === "cta" && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-4">Preview</p>
            <div class="rounded-xl border border-border/10 bg-card/30 p-8">
              <section class="relative overflow-hidden rounded-lg border border-accent/25 bg-primary/5 px-8 py-14 text-center shadow-hero">
                <h2 class="text-2xl font-bold text-foreground/90">Pronto para ter uma presença que vende?</h2>
                <p class="mt-3 text-base text-foreground/50 max-w-md mx-auto">
                  Comece com um diagnóstico gratuito e veja o que está impedindo seus clientes de te encontrar.
                </p>
                <div class="mt-7 flex flex-wrap items-center justify-center gap-3">
                  <a href="#" class="inline-flex items-center justify-center gap-2 rounded-lg text-sm font-medium h-11 px-6 bg-primary text-primary-foreground hover:bg-primary/90 transition-opacity">
                    Agendar diagnóstico
                  </a>
                  <a href="#" class="inline-flex items-center justify-center gap-2 rounded-lg text-sm font-medium h-11 px-6 border border-border/25 bg-transparent text-foreground/60 hover:border-primary/30 transition-colors">
                    Ver planos
                  </a>
                </div>
              </section>
            </div>
          </div>
        )}

        <!-- PRICING demo -->
        {block.slug === "pricing" && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-4">Preview</p>
            <div class="rounded-xl border border-border/10 bg-card/30 p-8">
              <div class="grid gap-4 sm:grid-cols-3">

                <!-- Card básico -->
                <div class="hover-lift relative flex flex-col rounded-lg border border-border/25 bg-card/90 p-7 shadow-card">
                  <div class="flex items-start justify-between gap-2">
                    <h3 class="text-base font-semibold text-foreground/90">Presença</h3>
                  </div>
                  <div class="mt-4 flex items-end gap-1">
                    <span class="text-3xl font-extrabold text-foreground/90">R$1.200</span>
                    <span class="mb-1 text-sm text-foreground/45">/ único</span>
                  </div>
                  <p class="mt-2 text-sm text-foreground/50">Site profissional e presença completa nas redes.</p>
                  <ul class="mt-5 flex flex-col gap-2">
                    {["Site one-page", "SEO básico", "Perfil Google"].map(f => (
                      <li class="flex items-start gap-2 text-sm text-foreground/70">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        {f}
                      </li>
                    ))}
                  </ul>
                  <a href="#" class="mt-7 inline-flex items-center justify-center w-full rounded-lg text-sm font-medium h-11 bg-accent/20 border border-accent/40 text-foreground/90 hover:bg-accent/30 transition-colors">
                    Quero este
                  </a>
                </div>

                <!-- Card highlight -->
                <div class="hover-lift relative flex flex-col rounded-lg border border-accent/40 bg-card/90 p-7 shadow-hero">
                  <span class="absolute inset-x-0 top-0 h-0.5 rounded-t-lg bg-primary"></span>
                  <div class="flex items-start justify-between gap-2">
                    <h3 class="text-base font-semibold text-foreground/90">Contínua</h3>
                    <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-accent/20 border border-accent/30 text-foreground/90">Popular</span>
                  </div>
                  <div class="mt-4 flex items-end gap-1">
                    <span class="text-3xl font-extrabold text-foreground/90">R$490</span>
                    <span class="mb-1 text-sm text-foreground/45">/ mês</span>
                  </div>
                  <p class="mt-2 text-sm text-foreground/50">Presença ativa com evolução mensal e estratégia.</p>
                  <ul class="mt-5 flex flex-col gap-2">
                    {["Tudo do básico", "Conteúdo mensal", "SEO avançado", "Relatório mensal"].map(f => (
                      <li class="flex items-start gap-2 text-sm text-foreground/70">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        {f}
                      </li>
                    ))}
                  </ul>
                  <a href="#" class="mt-7 inline-flex items-center justify-center w-full rounded-lg text-sm font-medium h-11 bg-primary text-primary-foreground hover:bg-primary/90 transition-opacity">
                    Quero este
                  </a>
                </div>

                <!-- Card enterprise -->
                <div class="hover-lift relative flex flex-col rounded-lg border border-border/25 bg-card/90 p-7 shadow-card">
                  <div class="flex items-start justify-between gap-2">
                    <h3 class="text-base font-semibold text-foreground/90">Clínica</h3>
                  </div>
                  <div class="mt-4 flex items-end gap-1">
                    <span class="text-3xl font-extrabold text-foreground/90">Sob consulta</span>
                  </div>
                  <p class="mt-2 text-sm text-foreground/50">Para clínicas e equipes com demandas específicas.</p>
                  <ul class="mt-5 flex flex-col gap-2">
                    {["Múltiplos profissionais", "Sistema de agendamento", "Suporte prioritário"].map(f => (
                      <li class="flex items-start gap-2 text-sm text-foreground/70">
                        <svg class="mt-0.5 h-4 w-4 shrink-0 text-primary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
                        {f}
                      </li>
                    ))}
                  </ul>
                  <a href="#" class="mt-7 inline-flex items-center justify-center w-full rounded-lg text-sm font-medium h-11 bg-accent/20 border border-accent/40 text-foreground/90 hover:bg-accent/30 transition-colors">
                    Falar com Carlos
                  </a>
                </div>

              </div>
            </div>
          </div>
        )}

        <!-- FAQ demo -->
        {block.slug === "faq" && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-4">Preview</p>
            <div class="rounded-xl border border-border/10 bg-card/30 p-8">
              <h2 class="mb-6 text-xl font-bold text-foreground/90 text-center">Perguntas frequentes</h2>
              <div class="mx-auto max-w-xl flex flex-col gap-2">
                <details class="group rounded-lg border border-border/18 bg-card/90 overflow-hidden open:border-primary/20">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-medium text-foreground/90 hover:bg-accent/5 transition-colors">
                    Quanto tempo leva para ter o site no ar?
                    <svg class="h-4 w-4 shrink-0 text-primary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="px-5 pb-4 text-sm text-foreground/55 leading-relaxed">
                    Em geral, de 7 a 14 dias úteis a partir da aprovação do briefing. Projetos mais complexos ou com mais páginas podem levar um pouco mais.
                  </div>
                </details>
                <details class="group rounded-lg border border-border/18 bg-card/90 overflow-hidden open:border-primary/20">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-medium text-foreground/90 hover:bg-accent/5 transition-colors">
                    Preciso fornecer as fotos e textos?
                    <svg class="h-4 w-4 shrink-0 text-primary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="px-5 pb-4 text-sm text-foreground/55 leading-relaxed">
                    Você fornece o que tiver disponível. O Studio adapta, organiza e, quando necessário, produz ou sugere alternativas editorias para o projeto.
                  </div>
                </details>
                <details class="group rounded-lg border border-border/18 bg-card/90 overflow-hidden open:border-primary/20">
                  <summary class="flex cursor-pointer list-none items-center justify-between gap-4 px-5 py-4 text-sm font-medium text-foreground/90 hover:bg-accent/5 transition-colors">
                    Vocês fazem manutenção depois do lançamento?
                    <svg class="h-4 w-4 shrink-0 text-primary transition-transform group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/></svg>
                  </summary>
                  <div class="px-5 pb-4 text-sm text-foreground/55 leading-relaxed">
                    Sim. O plano Presença Contínua cobre evolução mensal, SEO e suporte. Para projetos pontuais, existe a opção de pacote de horas.
                  </div>
                </details>
              </div>
            </div>
          </div>
        )}

        <!-- TESTIMONIAL demo -->
        {block.slug === "testimonial" && (
          <div>
            <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-4">Preview</p>
            <div class="rounded-xl border border-border/10 bg-card/30 p-8">
              <div class="grid gap-4 sm:grid-cols-3">
                {[
                  { quote: "O site ficou exatamente como eu imaginava — elegante, direto e profissional. Os agendamentos aumentaram no primeiro mês.", author: "Dra. Fernanda Lima", role: "Nutricionista" },
                  { quote: "Finalmente uma presença que combina com o meu trabalho. Os pacientes comentam que o site transmite confiança antes mesmo da consulta.", author: "Dr. Rafael Mota", role: "Fisioterapeuta" },
                  { quote: "Carlos entendeu minha proposta antes de eu terminar de explicar. O resultado superou muito o que eu esperava.", author: "Ana Carla Braga", role: "Psicóloga" },
                ].map(item => (
                  <figure class="hover-lift flex flex-col gap-4 rounded-lg border border-border/25 bg-card/90 p-6 shadow-card">
                    <blockquote class="text-sm text-foreground/70 leading-relaxed">
                      &ldquo;{item.quote}&rdquo;
                    </blockquote>
                    <figcaption class="flex items-center gap-3 mt-auto">
                      <div class="h-9 w-9 rounded-full bg-primary/15 ring-2 ring-accent/40 flex items-center justify-center text-xs font-bold text-primary">
                        {item.author[0]}
                      </div>
                      <div>
                        <div class="text-sm font-semibold text-foreground/90">{item.author}</div>
                        <div class="text-xs text-foreground/45">{item.role}</div>
                      </div>
                    </figcaption>
                  </figure>
                ))}
