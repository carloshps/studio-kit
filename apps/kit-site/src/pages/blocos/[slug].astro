  <script>
    const dialog  = document.getElementById("demo-modal") as HTMLDialogElement | null;
    const trigger = document.getElementById("demo-modal-trigger");
    const closeBtn = document.getElementById("demo-modal-close");
    const cancelBtn = document.getElementById("demo-modal-cancel");
    const confirmBtn = document.getElementById("demo-modal-confirm");

    trigger?.addEventListener("click", () => dialog?.showModal());
    closeBtn?.addEventListener("click", () => dialog?.close());
    cancelBtn?.addEventListener("click", () => dialog?.close());
    confirmBtn?.addEventListener("click", () => dialog?.close());

    // fechar ao clicar no backdrop (clique no <dialog> fora do conteúdo)
    dialog?.addEventListener("click", (e) => {
      if (e.target === dialog) dialog.close();
    });
  </script>

  <script define:vars={{ source: block.source }}>
    const btn = document.getElementById("copy-btn");
    const iconCopy = document.getElementById("icon-copy");
    const iconCheck = document.getElementById("icon-check");

    btn?.addEventListener("click", () => {
      navigator.clipboard.writeText(`npx shadcn add ${source}`).then(() => {
        iconCopy?.classList.add("hidden");
        iconCheck?.classList.remove("hidden");
        setTimeout(() => {
          iconCopy?.classList.remove("hidden");
          iconCheck?.classList.add("hidden");
        }, 1800);
      });
    });
  </script>
