---
import StyleguideLayout from "../layouts/StyleguideLayout.astro";
---

<StyleguideLayout title="Blocos">
  <div class="px-8 py-12 max-w-container mx-auto space-y-12">

    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-foreground/30 mb-2">Design System</p>
      <h1 class="text-h1 text-foreground/90 mb-3">Blocos</h1>
      <p class="text-body text-foreground/50 max-w-xl">
        Seções prontas para compor páginas de clientes. Cada bloco inclui preview, props e comando de instalação via registry.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
      {[
        {
          name: "Hero",
          href: "/blocos/hero",
          done: true,
          desc: "Eyebrow, título com highlight, subtitle e dual CTA",
          icon: `<path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/>`,
        },
        {
          name: "CTA Section",
          href: "/blocos/cta",
          done: true,
          desc: "Chamada para ação com borda accent e sombra hero",
          icon: `<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>`,
        },
        {
          name: "Pricing Card",
          href: "/blocos/pricing",
          done: true,
          desc: "Card de plano com features, highlight e badge",
          icon: `<line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/>`,
        },
        {
          name: "FAQ",
          href: "/blocos/faq",
          done: true,
          desc: "Accordion de perguntas com estado React",
          icon: `<circle cx="12" cy="12" r="10"/><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><line x1="12" y1="17" x2="12.01" y2="17"/>`,
        },
        {
          name: "Testimonial",
          href: "/blocos/testimonial",
          done: true,
          desc: "Grid de depoimentos com avatar e cargo",
          icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
        },
        {
          name: "Lead Form",
          href: "/blocos/lead-form",
          done: true,
          desc: "Formulário de captação com POST para API customizável",
          icon: `<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>`,
        },
        {
          name: "Metric Block",
          href: "/blocos/metric-block",
          done: true,
          desc: "Valor grande em primário com glow + label + descrição",
          icon: `<line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/>`,
        },
        {
          name: "Footer",
          href: "/blocos/footer",
          done: true,
          desc: "Rodapé com brand, colunas de links e copyright",
          icon: `<line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/>`,
        },
        {
          name: "Modal",
          href: "/blocos/modal",
          done: false,
          badge: "novo",
          desc: "Janela modal genérica baseada em Dialog com overlay",
          icon: `<rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><line x1="9" y1="9" x2="15" y2="15"/><line x1="15" y1="9" x2="9" y2="15"/>`,
        },
        {
          name: "Login",
          href: "/blocos/login",
          done: false,
          badge: "novo",
          desc: "Tela de autenticação com e-mail, senha e recuperação",
          icon: `<rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>`,
        },
      ].map(block => (
        <a
          href={block.href}
          class="group flex items-start gap-4 rounded-xl border border-border/10 bg-card/40 p-5 hover:border-primary/25 hover:bg-primary/4 transition-colors"
        >
          <!-- Ícone -->
          <div class={`shrink-0 w-10 h-10 rounded-xl flex items-center justify-center transition-colors ${block.done ? 'bg-primary/10 text-primary group-hover:bg-primary/15' : 'bg-foreground/5 text-foreground/25'}`}>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" set:html={block.icon}></svg>
          </div>

          <div class="flex-1 min-w-0">
            <div class="flex items-center gap-2 mb-1">
              <p class="text-sm font-semibold text-foreground/70 group-hover:text-primary transition-colors">
                {block.name}
              </p>
              {block.badge && (
                <span class="text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded-full bg-accent/20 text-foreground/40">
                  {block.badge}
                </span>
              )}
              {!block.done && (
                <span class="text-[9px] uppercase tracking-wide font-semibold px-1.5 py-0.5 rounded-full bg-foreground/8 text-foreground/30">
                  em breve
                </span>
              )}
            </div>
            <p class="text-xs text-foreground/35 truncate">{block.desc}</p>
          </div>

          <svg class="mt-0.5 shrink-0 text-foreground/15 group-hover:text-primary/50 transition-colors" width="12" height="12" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <path d="M2.5 7h9M7.5 3l4 4-4 4"/>
          </svg>
        </a>
      ))}
    </div>

    <!-- Legenda -->
    <div class="flex items-center gap-5 pt-2 text-xs text-foreground/30">
      <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-primary"></span>Disponível com demo</span>
      <span class="flex items-center gap-2"><span class="w-2 h-2 rounded-full bg-foreground/15"></span>Em construção</span>
    </div>

  </div>
</StyleguideLayout>
