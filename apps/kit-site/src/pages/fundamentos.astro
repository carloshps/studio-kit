---
import StyleguideLayout from "../layouts/StyleguideLayout.astro";
---

<StyleguideLayout title="Fundamentos">
  <div class="px-8 py-12 max-w-container mx-auto space-y-20">

    <!-- Título da página -->
    <div>
      <p class="text-xs font-semibold uppercase tracking-widest text-foreground/30 mb-3">Design System</p>
      <h1 class="text-h1 text-foreground/90 mb-3">Fundamentos</h1>
      <p class="text-body text-foreground/50 max-w-xl">
        Tokens base do Studio Kit — cores, tipografia, espaçamento, radius, sombras, marca e imagens.
      </p>
    </div>

    <!-- ─── CORES ─────────────────────────────────────────────────────── -->
    <section id="cores">
      <h2 class="text-h2 text-foreground/90 mb-1">Cores</h2>
      <p class="text-caption text-foreground/40 mb-8">Paleta semântica com tokens CSS. Dark é o tema principal; Light via classe <code class="font-mono bg-primary/8 text-primary px-1.5 py-0.5 rounded text-[11px]">.light</code>.</p>

      <!-- Cores principais side-by-side dark/light -->
      <div class="space-y-6">

        <!-- Fundo -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-3">Fundos</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
            {[
              { token: "--background",           dark: "#081424", light: "#F8FAFC", label: "Background" },
              { token: "--background-secondary",  dark: "#030C17", light: "#F1F5F9", label: "Background Secondary" },
              { token: "--card",                  dark: "#081424", light: "#FFFFFF", label: "Card" },
            ].map(c => (
              <div class="rounded-xl border border-border/10 overflow-hidden">
                <div class="flex h-16">
                  <div class="flex-1" style={`background:${c.dark}`} title="dark"></div>
                  <div class="flex-1 border-l border-border/10" style={`background:${c.light}`} title="light"></div>
                </div>
                <div class="px-3 py-2.5 bg-card/40">
                  <p class="text-[11px] font-semibold text-foreground/70">{c.label}</p>
                  <p class="text-[10px] font-mono text-foreground/30 mt-0.5">{c.token}</p>
                  <div class="flex gap-2 mt-1">
                    <span class="text-[10px] font-mono text-foreground/30">{c.dark}</span>
                    <span class="text-[10px] text-foreground/20">·</span>
                    <span class="text-[10px] font-mono text-foreground/30">{c.light}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Acento / Primary -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-3">Acento (ambos os temas)</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
            {[
              { token: "--primary / --accent",  hex: "#00ADCF", label: "Cyan — cor principal" },
              { token: "--primary-foreground",  hex: "#E8F4FB", label: "Texto sobre primary" },
              { token: "--ring",                hex: "#00ADCF", label: "Focus ring" },
            ].map(c => (
              <div class="rounded-xl border border-border/10 overflow-hidden">
                <div class="h-16" style={`background:${c.hex}`}></div>
                <div class="px-3 py-2.5 bg-card/40">
                  <p class="text-[11px] font-semibold text-foreground/70">{c.label}</p>
                  <p class="text-[10px] font-mono text-foreground/30 mt-0.5">{c.token}</p>
                  <span class="text-[10px] font-mono text-foreground/30">{c.hex}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Texto -->
        <div>
          <p class="text-xs font-semibold uppercase tracking-widest text-foreground/25 mb-3">Texto</p>
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-3">
            {[
              { token: "--foreground",  dark: "#E8F4FB", light: "#081424", label: "Foreground" },
              { token: "--destructive", dark: "#EF4444", light: "#EF4444", label: "Destructive" },
            ].map(c => (
              <div class="rounded-xl border border-border/10 overflow-hidden">
                <div class="flex h-16">
                  <div class="flex-1" style={`background:${c.dark}`}></div>
                  <div class="flex-1 border-l border-border/10" style={`background:${c.light}`}></div>
                </div>
                <div class="px-3 py-2.5 bg-card/40">
                  <p class="text-[11px] font-semibold text-foreground/70">{c.label}</p>
                  <p class="text-[10px] font-mono text-foreground/30 mt-0.5">{c.token}</p>
                  <div class="flex gap-2 mt-1">
                    <span class="text-[10px] font-mono text-foreground/30">{c.dark}</span>
                    <span class="text-[10px] text-foreground/20">·</span>
                    <span class="text-[10px] font-mono text-foreground/30">{c.light}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Legenda dark/light -->
        <div class="flex items-center gap-4 text-[10px] text-foreground/30">
          <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm" style="background:#081424; border:1px solid rgba(255,255,255,0.1)"></span>Dark</span>
          <span class="flex items-center gap-1.5"><span class="w-3 h-3 rounded-sm" style="background:#F8FAFC; border:1px solid rgba(0,0,0,0.1)"></span>Light</span>
        </div>
      </div>
    </section>

    <!-- ─── TIPOGRAFIA ─────────────────────────────────────────────────── -->
    <section id="tipografia">
      <h2 class="text-h2 text-foreground/90 mb-1">Tipografia</h2>
      <p class="text-caption text-foreground/40 mb-8">Família única: <strong class="font-semibold text-foreground/60">Manrope</strong>. Nunca misturar com outra fonte. Escala com clamp para display e h1.</p>

      <div class="rounded-2xl border border-border/10 bg-card/30 divide-y divide-border/10 overflow-hidden">
        {[
          { cls: "text-display",  name: "Display",  size: "clamp(2.5rem, 5vw, 4rem)", weight: "800", sample: "Design system autoral" },
          { cls: "text-h1",       name: "H1",       size: "clamp(2rem, 4vw, 3rem)",   weight: "700", sample: "Título principal da página" },
          { cls: "text-h2",       name: "H2",       size: "1.875rem",                 weight: "700", sample: "Seção de conteúdo" },
          { cls: "text-h3",       name: "H3",       size: "1.375rem",                 weight: "600", sample: "Subseção e cards" },
          { cls: "text-body-lg",  name: "Body LG",  size: "1.125rem",                 weight: "400", sample: "Texto introdutório e subtítulos de seção com espaço de leitura." },
          { cls: "text-body",     name: "Body",     size: "1rem",                     weight: "400", sample: "Texto corrido de parágrafos, descrições e instruções gerais." },
          { cls: "text-caption",  name: "Caption",  size: "0.8125rem",                weight: "400", sample: "Labels, metadados, notas de rodapé e texto auxiliar." },
        ].map(t => (
          <div class="flex flex-col sm:flex-row sm:items-center gap-4 px-6 py-5">
            <div class="shrink-0 w-32">
              <p class="text-[11px] font-semibold text-foreground/60">{t.name}</p>
              <p class="text-[10px] font-mono text-foreground/30 mt-0.5">{t.size}</p>
              <p class="text-[10px] font-mono text-foreground/25">w{t.weight}</p>
            </div>
            <p class={`${t.cls} text-foreground/80 leading-tight`}>{t.sample}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── ESPAÇAMENTO ───────────────────────────────────────────────── -->
    <section id="espacamento">
      <h2 class="text-h2 text-foreground/90 mb-1">Espaçamento</h2>
      <p class="text-caption text-foreground/40 mb-8">Tokens de ritmo — usados em <code class="font-mono bg-primary/8 text-primary px-1.5 py-0.5 rounded text-[11px]">py-section</code>, <code class="font-mono bg-primary/8 text-primary px-1.5 py-0.5 rounded text-[11px]">px-gutter</code> e <code class="font-mono bg-primary/8 text-primary px-1.5 py-0.5 rounded text-[11px]">max-w-container</code>.</p>

      <div class="space-y-4">
        {[
          { name: "section",     token: "spacing.section",     value: "6rem / 96px",  desc: "Padding vertical de seções maiores (hero, cta)" },
          { name: "section-sm",  token: "spacing.section-sm",  value: "4rem / 64px",  desc: "Padding vertical de seções internas" },
          { name: "gutter",      token: "spacing.gutter",      value: "1.5rem / 24px", desc: "Padding horizontal padrão de seções" },
          { name: "container",   token: "maxWidth.container",  value: "64rem / 1024px", desc: "Largura máxima do conteúdo" },
        ].map(s => (
          <div class="flex items-center gap-4 rounded-xl border border-border/10 bg-card/30 px-5 py-4">
            <div class="shrink-0 w-28">
              <p class="text-[11px] font-semibold text-foreground/60">{s.name}</p>
              <p class="text-[10px] font-mono text-foreground/30 mt-0.5">{s.token}</p>
            </div>
            <div class="flex-1 bg-primary/8 rounded-lg h-3 max-w-xs" style={`width: min(100%, ${s.value.includes("96") ? "96px" : s.value.includes("64px") ? "64px" : s.value.includes("24px") ? "24px" : "200px"})`}></div>
            <div class="text-right shrink-0">
              <p class="text-[11px] font-mono text-foreground/50">{s.value}</p>
              <p class="text-[10px] text-foreground/30 mt-0.5">{s.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── RADIUS ────────────────────────────────────────────────────── -->
    <section id="radius">
      <h2 class="text-h2 text-foreground/90 mb-1">Radius</h2>
      <p class="text-caption text-foreground/40 mb-8">
        Token base: <code class="font-mono bg-primary/8 text-primary px-1.5 py-0.5 rounded text-[11px]">--radius: 0.5rem</code>. Tailwind deriva <code class="font-mono bg-primary/8 text-primary px-1.5 py-0.5 rounded text-[11px]">rounded-lg</code>, <code class="font-mono bg-primary/8 text-primary px-1.5 py-0.5 rounded text-[11px]">rounded-xl</code> etc. Para re-branding, altere apenas <code class="font-mono bg-primary/8 text-primary px-1.5 py-0.5 rounded text-[11px]">--radius</code>.
      </p>

      <div class="flex flex-wrap gap-6 items-end">
        {[
          { label: "Nenhum",   cls: "rounded-none",  val: "0rem",    use: "Tabelas, separadores" },
          { label: "sm",       cls: "rounded-sm",    val: "0.125rem", use: "Tags internas" },
          { label: "md (base)",cls: "rounded-md",    val: "0.375rem", use: "Botões, inputs" },
          { label: "lg",       cls: "rounded-lg",    val: "0.5rem",   use: "Cards, panels" },
          { label: "xl",       cls: "rounded-xl",    val: "0.75rem",  use: "Modais, drawers" },
          { label: "2xl",      cls: "rounded-2xl",   val: "1rem",     use: "Hero cards, CTAs" },
          { label: "full",     cls: "rounded-full",  val: "9999px",   use: "Badges, avatares" },
        ].map(r => (
          <div class="flex flex-col items-center gap-2">
            <div
              class={`w-14 h-14 bg-primary/20 border-2 border-primary/40 ${r.cls}`}
            ></div>
            <p class="text-[11px] font-semibold text-foreground/60 text-center">{r.label}</p>
            <p class="text-[10px] font-mono text-foreground/30 text-center">{r.val}</p>
            <p class="text-[10px] text-foreground/25 text-center max-w-[80px] leading-tight">{r.use}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── SOMBRAS ───────────────────────────────────────────────────── -->
    <section id="sombras">
      <h2 class="text-h2 text-foreground/90 mb-1">Sombras</h2>
      <p class="text-caption text-foreground/40 mb-8">Sombras theme-aware via <code class="font-mono bg-primary/8 text-primary px-1.5 py-0.5 rounded text-[11px]">var(--shadow-*)</code>. Mudam automaticamente no tema light.</p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {[
          { name: "hero",    cls: "shadow-hero",   token: "--shadow-hero",   use: "Seções hero, modal principal, cards de destaque" },
          { name: "card",    cls: "shadow-card",   token: "--shadow-card",   use: "Cards de conteúdo, painéis laterais" },
          { name: "metric",  cls: "shadow-metric", token: "--shadow-metric", use: "Cards de métricas, números em destaque" },
          { name: "glow",    cls: "shadow-glow",   token: "--shadow-glow",   use: "Botão primário hover, ícones em destaque" },
          { name: "lift",    cls: "shadow-lift",   token: "--shadow-lift",   use: "Elevação + glow no hover de cards (hover-lift)" },
        ].map(s => (
          <div class="flex flex-col gap-3">
            <div class={`rounded-xl border border-border/10 bg-card/60 px-6 py-8 ${s.cls} flex items-center justify-center`}>
              <div class="text-center">
                <p class="text-sm font-semibold text-foreground/70">{s.name}</p>
                <p class="text-[10px] font-mono text-foreground/30 mt-1">{s.token}</p>
              </div>
            </div>
            <p class="text-xs text-foreground/35 px-1">{s.use}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- ─── ANIMAÇÕES & EFEITOS ───────────────────────────────────────── -->
    <section id="animacoes">
      <h2 class="text-h2 text-foreground/90 mb-1">Animações & efeitos</h2>
      <p class="text-caption text-foreground/40 mb-8">Microinterações da identidade Studio. Utilitários prontos — todos respeitam <code class="font-mono bg-primary/8 text-primary px-1.5 py-0.5 rounded text-[11px]">prefers-reduced-motion</code>.</p>

      <div class="space-y-6">

        <!-- Glow no título -->
        <div class="rounded-xl border border-border/10 bg-card/30 p-8">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
            <div>
              <p class="text-sm font-semibold text-foreground/70">Destaque com glow</p>
              <p class="text-xs text-foreground/40 mt-0.5">Gradiente azul-marca → accent recortado no texto, com glow suave.</p>
            </div>
            <code class="font-mono text-[11px] bg-primary/8 text-primary px-2 py-1 rounded">.hl</code>
          </div>
          <p class="text-2xl sm:text-3xl font-extrabold text-foreground/90 leading-tight">
            Não entregamos templates. <span class="hl">Criamos presença.</span>
          </p>
        </div>

        <!-- Hover lift -->
        <div class="rounded-xl border border-border/10 bg-card/30 p-8">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
            <div>
              <p class="text-sm font-semibold text-foreground/70">Elevação no hover</p>
              <p class="text-xs text-foreground/40 mt-0.5">Card sobe 4px e ganha glow. Passe o mouse nos cards abaixo.</p>
            </div>
            <code class="font-mono text-[11px] bg-primary/8 text-primary px-2 py-1 rounded">.hover-lift</code>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
            {["Presença", "Captação", "Marca"].map(t => (
              <div class="hover-lift rounded-lg border border-border/25 bg-card/80 p-5 shadow-card">
                <p class="text-sm font-semibold text-foreground/80">{t}</p>
                <p class="text-xs text-foreground/40 mt-1">Passe o mouse para ver a elevação.</p>
              </div>
            ))}
          </div>
        </div>

        <!-- Botão shine -->
        <div class="rounded-xl border border-border/10 bg-card/30 p-8">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
            <div>
              <p class="text-sm font-semibold text-foreground/70">Brilho no botão + ícone</p>
              <p class="text-xs text-foreground/40 mt-0.5">Padrão em todos os botões — primário, outline e variantes. Passe o mouse para ver o brilho varrer.</p>
            </div>
            <code class="font-mono text-[11px] bg-primary/8 text-primary px-2 py-1 rounded">.btn-shine</code>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <button class="btn-shine overflow-hidden relative inline-flex items-center justify-center gap-2 rounded-lg text-sm font-medium h-11 px-6 bg-primary text-primary-foreground transition-transform duration-200 hover:-translate-y-0.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
              Falar no WhatsApp
            </button>
            <button class="btn-shine overflow-hidden relative inline-flex items-center justify-center gap-2 rounded-lg text-sm font-medium h-11 px-6 border border-border/25 bg-transparent text-foreground/70 transition-transform duration-200 hover:-translate-y-0.5 hover:border-accent/40">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15 9 22 9 17 14 19 21 12 17 5 21 7 14 2 9 9 9"/></svg>
              Ver cases
            </button>
            <button class="btn-shine overflow-hidden relative inline-flex items-center justify-center gap-2 rounded-lg text-sm font-medium h-11 px-6 bg-accent/20 border border-accent/40 text-foreground/90 transition-transform duration-200 hover:-translate-y-0.5 hover:bg-accent/30">
              Default
            </button>
          </div>
        </div>

        <!-- Marquee -->
        <div class="rounded-xl border border-border/10 bg-card/30 p-8">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-6">
            <div>
              <p class="text-sm font-semibold text-foreground/70">Marquee contínuo</p>
              <p class="text-xs text-foreground/40 mt-0.5">Rolagem infinita com fade nas bordas. Base do componente Carousel.</p>
            </div>
            <code class="font-mono text-[11px] bg-primary/8 text-primary px-2 py-1 rounded">animate-marquee</code>
          </div>
          <div class="marquee-mask w-full overflow-hidden">
            <div class="flex w-max animate-marquee gap-3">
              {[...Array(2)].flatMap(() => ["Núcleo", "Sorrir Bem", "VitalCare", "Movimento", "Clareza", "Equilíbrio"]).map(n => (
                <div class="shrink-0 flex items-center justify-center h-12 px-6 rounded-lg border border-border/15 bg-card/60 text-sm font-semibold text-foreground/50">{n}</div>
              ))}
            </div>
          </div>
        </div>

        <!-- Reveal -->
        <div class="rounded-xl border border-border/10 bg-card/30 p-8">
          <div class="flex items-start justify-between gap-4 flex-wrap mb-2">
            <div>
              <p class="text-sm font-semibold text-foreground/70">Reveal na entrada</p>
              <p class="text-xs text-foreground/40 mt-0.5">Fade + sobe ao surgir. Combine com IntersectionObserver para revelar no scroll.</p>
            </div>
            <code class="font-mono text-[11px] bg-primary/8 text-primary px-2 py-1 rounded">animate-reveal</code>
          </div>
        </div>

      </div>
    </section>

    <!-- ─── MARCA & LOGO ──────────────────────────────────────────────── -->
    <section id="marca">
      <h2 class="text-h2 text-foreground/90 mb-1">Marca & Logo</h2>
      <p class="text-caption text-foreground/40 mb-8">Identidade visual do CarlosHPS Studio. Usar apenas nos formatos aprovados.</p>

      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Logo principal -->
        <div class="rounded-2xl border border-border/10 bg-card/40 p-8 flex items-center justify-center min-h-40">
          <div class="flex items-center gap-3">
            <span class="w-9 h-9 rounded-lg bg-primary flex items-center justify-center shrink-0">
              <svg width="18" height="18" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1" y="1" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground"/>
                <rect x="7" y="1" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground/60"/>
                <rect x="1" y="7" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground/60"/>
                <rect x="7" y="7" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground/30"/>
              </svg>
            </span>
            <div>
              <p class="text-sm font-bold text-foreground/90 leading-none">Studio Kit</p>
              <p class="text-[10px] text-foreground/40 mt-0.5">CarlosHPS Studio</p>
            </div>
          </div>
        </div>

        <!-- Logo sobre fundo claro -->
        <div class="rounded-2xl border border-border/10 p-8 flex items-center justify-center min-h-40" style="background:#F8FAFC">
          <div class="flex items-center gap-3">
            <span class="w-9 h-9 rounded-lg flex items-center justify-center shrink-0" style="background:#00ADCF">
              <svg width="18" height="18" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect x="1" y="1" width="4" height="4" rx="0.5" fill="white"/>
                <rect x="7" y="1" width="4" height="4" rx="0.5" fill="white" opacity="0.6"/>
                <rect x="1" y="7" width="4" height="4" rx="0.5" fill="white" opacity="0.6"/>
                <rect x="7" y="7" width="4" height="4" rx="0.5" fill="white" opacity="0.3"/>
              </svg>
            </span>
            <div>
              <p class="text-sm font-bold leading-none" style="color:#081424">Studio Kit</p>
              <p class="text-[10px] mt-0.5" style="color:rgba(8,20,36,0.4)">CarlosHPS Studio</p>
            </div>
          </div>
        </div>

        <!-- Ícone solo -->
        <div class="rounded-2xl border border-border/10 bg-card/40 p-8 flex flex-col items-center justify-center min-h-40 gap-4">
          <span class="w-12 h-12 rounded-xl bg-primary flex items-center justify-center">
            <svg width="22" height="22" viewBox="0 0 12 12" fill="none" xmlns="http://www.w3.org/2000/svg">
              <rect x="1" y="1" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground"/>
              <rect x="7" y="1" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground/60"/>
              <rect x="1" y="7" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground/60"/>
              <rect x="7" y="7" width="4" height="4" rx="0.5" fill="currentColor" class="text-primary-foreground/30"/>
            </svg>
          </span>
          <p class="text-xs text-foreground/40 text-center">Ícone solo — favicons, avatares</p>
        </div>
      </div>

      <!-- Regras de uso -->
      <div class="mt-4 grid gap-3 sm:grid-cols-2">
        <div class="rounded-xl border border-green-500/15 bg-green-500/5 px-4 py-3">
          <p class="text-xs font-semibold text-green-400/80 mb-2">Permitido</p>
          <ul class="space-y-1 text-xs text-foreground/40">
